database -open waves -into waves.shm -default
probe -create -shm fifo_behavioral_tb.clk fifo_behavioral_tb.data_in fifo_behavioral_tb.data_out fifo_behavioral_tb.empty fifo_behavioral_tb.full fifo_behavioral_tb.i fifo_behavioral_tb.neg_reset fifo_behavioral_tb.re_en fifo_behavioral_tb.wr_en
run
exit
