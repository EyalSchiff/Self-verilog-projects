database -open waves -into waves.shm -default
probe -create -shm fifo_behavioral_tb.uut.clk fifo_behavioral_tb.uut.data_in fifo_behavioral_tb.uut.data_out fifo_behavioral_tb.uut.empty fifo_behavioral_tb.uut.fifo_mem fifo_behavioral_tb.uut.full fifo_behavioral_tb.uut.neg_reset fifo_behavioral_tb.uut.re_en fifo_behavioral_tb.uut.re_ptr fifo_behavioral_tb.uut.wr_en fifo_behavioral_tb.uut.wr_ptr
run
exit
